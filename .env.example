# Backend selection: 'supabase' (default) or 'firebase'
VITE_BACKEND=supabase

# Supabase (used when VITE_BACKEND=supabase)
# Get these from: https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Firebase (used when VITE_BACKEND=firebase)
# Get these from: https://console.firebase.google.com → your project → Project settings → General → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
